pipeline {
    agent any

    environment {
        IMAGE_NAME = "veeradockerhub/bikerental-app" // Your Docker Hub repo
        CONTAINER_NAME = "bikerental-container"
        FRONTEND_PORT = "3000"
        BACKEND_PORT = "3001"
        DOCKERHUB_CREDENTIALS = 'dockerhub-cred' // Jenkins credentials ID for Docker Hub
        KEEP_LATEST = 2 // number of latest images to keep
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/veeraprasadkoduri-cmd/veera.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    sh """
                        docker build -t $IMAGE_NAME:latest .
                    """
                }
            }
        }

        stage('Login to Docker Hub') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: "$DOCKERHUB_CREDENTIALS", 
                                                     usernameVariable: 'DOCKER_USER', 
                                                     passwordVariable: 'DOCKER_PASS')]) {
                        sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    sh """
                        docker push $IMAGE_NAME:latest
                    """
                }
            }
        }

        stage('Cleanup Old Images on Docker Hub') {
            steps {
                script {
                    echo "🔹 Cleanup old images (keep last $KEEP_LATEST)"
                    // This requires Docker Hub API token to delete old tags
                    sh """
                    TOK=$(curl -s -H "Content-Type: application/json" -X POST -d '{"username":"$DOCKER_USER","password":"$DOCKER_PASS"}' https://hub.docker.com/v2/users/login/ | jq -r .token)
                    TAGS=$(curl -s -H "Authorization: JWT \$TOK" "https://hub.docker.com/v2/repositories/veeradockerhub/bikerental-app/tags/?page_size=100" | jq -r '.results | sort_by(.last_updated) | .[:-${KEEP_LATEST}] | .[].name')
                    for t in \$TAGS; do
                        curl -s -X DELETE -H "Authorization: JWT \$TOK" "https://hub.docker.com/v2/repositories/veeradockerhub/bikerental-app/tags/\$t/"
                    done
                    """
                }
            }
        }

        stage('Deploy Container') {
            steps {
                script {
                    sh """
                        # Stop & remove old container if exists
                        docker stop $CONTAINER_NAME || true
                        docker rm $CONTAINER_NAME || true

                        # Run new container
                        docker run -d -p $FRONTEND_PORT:3000 -p $BACKEND_PORT:3001 --name $CONTAINER_NAME $IMAGE_NAME:latest
                    """
                }
            }
        }

    }

    post {
        success {
            echo "✅ Deployment successful! Frontend: http://<EC2-IP>:$FRONTEND_PORT | Backend: http://<EC2-IP>:$BACKEND_PORT"
        }
        failure {
            echo "❌ Pipeline failed!"
        }
    }
}
