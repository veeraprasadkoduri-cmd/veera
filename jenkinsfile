pipeline {
    agent any

    environment {
        IMAGE_NAME = "bikerental-app"
        CONTAINER_NAME = "bikerental-container"
    }

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main', url: 'https://github.com/veeraprasadkoduri-cmd/veera.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $IMAGE_NAME .'
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                docker stop $CONTAINER_NAME || true
                docker rm $CONTAINER_NAME || true
                docker run -d -p 91:80 --name $CONTAINER_NAME $IMAGE_NAME
                '''
            }
        }

    }
}
