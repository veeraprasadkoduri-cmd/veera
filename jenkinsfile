pipeline {
    agent any

    environment {
        IMAGE_NAME = "bikerental-app"
        CONTAINER_NAME = "bikerental-container"
        FRONTEND_PORT = "3000"
        BACKEND_PORT = "3001"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/veeraprasadkoduri-cmd/veera.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    sh """
                        docker build -t $IMAGE_NAME:latest .
                    """
                }
            }
        }

        stage('Deploy Container') {
            steps {
                script {
                    sh """
                        # Stop & remove old container if exists
                        docker stop $CONTAINER_NAME || true
                        docker rm $CONTAINER_NAME || true

                        # Run new container
                        docker run -d -p $FRONTEND_PORT:3000 -p $BACKEND_PORT:3001 --name $CONTAINER_NAME $IMAGE_NAME:latest
                    """
                }
            }
        }

    }

    post {
        success {
            echo "✅ Deployment successful! Frontend: http://<EC2-IP>:$FRONTEND_PORT | Backend: http://<EC2-IP>:$BACKEND_PORT"
        }
        failure {
            echo "❌ Pipeline failed!"
        }
    }
}
